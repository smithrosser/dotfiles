# Global Settings
font=Source Sans 3 11
width=300
height=200
margin=20
padding=15
border-size=2
border-radius=8
icons=1
max-icon-size=32

# Timeout after 5 seconds
default-timeout=5000

# Tokyo Night Colors
background-color=#24283b
text-color=#c0caf5
border-color=#bb9af7
progress-color=over #3b4261

[urgency=low]
border-color=#414868
default-timeout=5000

[urgency=high]
border-color=#f7768e
text-color=#f7768e
default-timeout=0
